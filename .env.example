NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backend mode
# Options: supabase, local
DATABASE_MODE=supabase
STORAGE_MODE=supabase

# Local PostgreSQL / local file storage fallback
LOCAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_photo_studio_dev
LOCAL_UPLOAD_DIR=./uploads
NEXT_PUBLIC_LOCAL_UPLOAD_BASE_URL=/uploads

# AI Provider Settings
# Options: mock, gemini, replicate
# Default: mock (safe for local development)
AI_PROVIDER=mock

# Gemini API (for Phase 6 test foundation)
# Get key from: https://aistudio.google.com/
GEMINI_API_KEY=

# Replicate API (for Phase 6 live test)
# Get token from: https://replicate.com/
REPLICATE_API_TOKEN=

# Replicate image-to-image model (REQUIRED for uploaded photo editing)
# IMPORTANT: Must be an image-to-image or image-edit model that accepts an "image" input parameter.
# DO NOT use text-to-image-only models like:
#   - black-forest-labs/flux-schnell (text-to-image only - NO image input)
#   - black-forest-labs/flux-dev (text-to-image only - NO image input)
#   - stability-ai/sd3-medium (text-to-image only - NO image input)
#
# Suitable models for uploaded photo editing (must have image/image_url parameter):
#   - stability-ai/stable-diffusion-img2img (recommended for start)
#   - tomfreeman/transformerlm-1
#   - lucataco/flux-dev-3d
#   - lucataco/sdxl-img2img
#
# How to verify a model supports image input:
#   1. Go to https://replicate.com/{model-slug}/versions
#   2. Look at the input schema
#   3. Must have "image", "input_image", "init_image", or "source_image" parameter
#   4. If only prompt/width/height/num_outputs exist, it is text-to-image ONLY
#
# Run validation script: npx tsx scripts/check-replicate-model.ts
REPLICATE_IMAGE_MODEL=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin authorization
# Preferred: set profiles.role to admin, owner, or super_admin.
# Optional server-only fallback allowlist:
ADMIN_EMAILS=admin@uuree.mn

# Production admin setup
# Used only by: npm run setup:production-admin
# Do not use the local/dev password 123456 in production.
PRODUCTION_ADMIN_EMAIL=admin@uuree.mn
PRODUCTION_ADMIN_PASSWORD=
PRODUCTION_ADMIN_ROLE=owner

# Playwright local/dev admin E2E seed account
# Use non-production credentials only. The test setup creates/updates this
# Supabase Auth user and assigns role=admin in local/Supabase profiles.
# Must differ from PRODUCTION_ADMIN_EMAIL.
E2E_ADMIN_EMAIL=e2e-admin@uuree.mn
E2E_ADMIN_PASSWORD=123456

# Optional non-admin E2E account used to verify fail-closed admin access.
E2E_CUSTOMER_EMAIL=e2e-customer@example.com
E2E_CUSTOMER_PASSWORD=change-this-local-e2e-password

QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=
